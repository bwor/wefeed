.container {
  min-height: 100vh;
  background: #fffdf8;
  padding-bottom: 160rpx;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: #fff;
  border-bottom: 2rpx solid #ffe5c2;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 48rpx;
  color: #ff8c42;
  font-weight: 300;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.nav-right {
  width: 60rpx;
}

/* 头像区域 */
.avatar-section {
  display: flex;
  justify-content: center;
  padding: 40rpx 0;
}

.avatar-upload {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: #fff;
  border: 4rpx dashed #ffccaa;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.avatar-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.avatar-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.camera-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.upload-text {
  font-size: 24rpx;
  color: #ff9a6a;
}

/* 表单 */
.form {
  padding: 0 30rpx;
}

.form-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 4rpx 12rpx rgba(255, 165, 0, 0.05);
}

.item-left {
  display: flex;
  align-items: center;
}

.required {
  color: #ff5a5f;
  margin-right: 8rpx;
  font-size: 28rpx;
}

.label {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.input {
  font-size: 28rpx;
  color: #333;
  text-align: right;
  width: 300rpx;
}

.input-wrapper {
  display: flex;
  align-items: center;
}

.weight-input {
  width: 100rpx;
  text-align: right;
  margin-right: 10rpx;
}

.unit {
  font-size: 28rpx;
  color: #666;
}

.picker-value {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #333;
}

.arrow {
  margin-left: 12rpx;
  color: #ccc;
  font-size: 32rpx;
}

.placeholder {
  color: #999;
}

/* 开关项 */
.switch-item {
  justify-content: space-between;
}

/* 文本域项 */
.textarea-item {
  flex-direction: column;
  align-items: flex-start;
}

.textarea-item .item-left {
  margin-bottom: 20rpx;
}

.textarea {
  width: 100%;
  height: 160rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

/* 底部按钮 */
.footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 30rpx;
  background: #fff;
  border-top: 2rpx solid #ffe5c2;
}

.save-btn {
  background: linear-gradient(135deg, #ff9a6a 0%, #ff7e5f 100%);
  color: white;
  height: 96rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 25rpx rgba(255, 126, 95, 0.4);
}

.save-btn.disabled {
  opacity: 0.7;
}

.save-btn:active {
  transform: scale(0.98);
}
