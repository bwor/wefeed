/* 容器 */
.container {
  min-height: 100vh;
  background: #fffdf8;
  padding-bottom: 160rpx;
}

/* 头像区域 */
.avatar-section {
  display: flex;
  justify-content: center;
  padding: 40rpx 0;
}

.avatar-upload {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: #fff;
  border: 4rpx dashed #ffccaa;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.avatar-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.avatar-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.camera-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.upload-text {
  font-size: 24rpx;
  color: #ff9a6a;
}

/* 表单 */
.form {
  padding: 0 30rpx;
}

.form-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.item-left {
  margin-bottom: 16rpx;
}

.required {
  color: #ff5a5f;
  margin-right: 8rpx;
  font-size: 28rpx;
}

.label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.input {
  font-size: 28rpx;
  color: #333;
  width: 100%;
  padding: 16rpx 0;
}

.input-wrapper {
  display: flex;
  align-items: center;
}

.weight-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.unit {
  font-size: 28rpx;
  color: #666;
  margin-left: 8rpx;
}

.picker {
  width: 100%;
  padding: 16rpx 0;
}

.picker-value {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 28rpx;
  color: #333;
  padding: 16rpx 0;
}

.arrow {
  color: #ccc;
  font-size: 32rpx;
}

.placeholder {
  color: #999;
}

/* 开关项 */
.switch-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.switch-item .item-left {
  margin-bottom: 0;
}

/* 文本域项 */
.textarea-item {
  display: block;
}

.textarea-item .item-left {
  margin-bottom: 16rpx;
}

.textarea {
  width: 100%;
  height: 160rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  padding: 16rpx 0;
}

/* 底部按钮 */
.footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 30rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
}

.save-btn {
  background: linear-gradient(135deg, #ff9a6a 0%, #ff7e5f 100%);
  color: white;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 20rpx rgba(255, 126, 95, 0.3);
}

.save-btn.disabled {
  opacity: 0.7;
}

.save-btn:active {
  transform: scale(0.98);
}