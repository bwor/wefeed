<view class="container">
  <!-- 顶部导航 -->
  <view class="nav-bar">
    <view class="back-btn" bindtap="goBack">
      <text class="back-icon">‹</text>
    </view>
    <text class="nav-title">{{petId ? '编辑宠物' : '添加宠物'}}</text>
    <view class="nav-right"></view>
  </view>

  <!-- 头像上传 -->
  <view class="avatar-section">
    <view class="avatar-upload" bindtap="chooseAvatar">
      <image wx:if="{{tempAvatar}}" class="avatar-img" src="{{tempAvatar}}" mode="aspectFill"></image>
      <image wx:elif="{{avatar}}" class="avatar-img" src="{{avatar}}" mode="aspectFill"></image>
      <view wx:else class="avatar-placeholder">
        <text class="camera-icon">📷</text>
        <text class="upload-text">上传头像</text>
      </view>
    </view>
  </view>

  <!-- 表单 -->
  <view class="form">
    <!-- 名字 -->
    <view class="form-item">
      <view class="item-left">
        <view class="required">*</view>
        <text class="label">名字</text>
      </view>
      <input class="input" placeholder="请输入宠物名字" value="{{name}}" data-field="name" bindinput="onInput" />
    </view>

    <!-- 类型 -->
    <view class="form-item">
      <view class="item-left">
        <text class="label">类型</text>
      </view>
      <picker bindchange="onTypeChange" value="{{type === 'cat' ? 0 : type === 'dog' ? 1 : 2}}" range="{{typeOptions}}" range-key="label">
        <view class="picker-value">
          <text>{{type === 'cat' ? '猫咪' : type === 'dog' ? '狗狗' : '其他'}}</text>
          <text class="arrow">›</text>
        </view>
      </picker>
    </view>

    <!-- 品种 -->
    <view class="form-item">
      <view class="item-left">
        <text class="label">品种</text>
      </view>
      <input class="input" placeholder="请输入品种" value="{{breed}}" data-field="breed" bindinput="onInput" />
    </view>

    <!-- 性别 -->
    <view class="form-item">
      <view class="item-left">
        <text class="label">性别</text>
      </view>
      <picker bindchange="onGenderChange" value="{{gender === 'male' ? 0 : gender === 'female' ? 1 : 2}}" range="{{genderOptions}}" range-key="label">
        <view class="picker-value">
          <text>{{gender === 'male' ? '公' : gender === 'female' ? '母' : '未知'}}</text>
          <text class="arrow">›</text>
        </view>
      </picker>
    </view>

    <!-- 生日 -->
    <view class="form-item">
      <view class="item-left">
        <text class="label">生日</text>
      </view>
      <picker mode="date" value="{{birthday}}" bindchange="onDateChange">
        <view class="picker-value">
          <text wx:if="{{birthday}}">{{birthday}}</text>
          <text wx:else class="placeholder">选择生日</text>
          <text class="arrow">›</text>
        </view>
      </picker>
    </view>

    <!-- 体重 -->
    <view class="form-item">
      <view class="item-left">
        <text class="label">体重</text>
      </view>
      <view class="input-wrapper">
        <input class="input weight-input" placeholder="0.0" type="digit" value="{{weight}}" data-field="weight" bindinput="onInput" />
        <text class="unit">kg</text>
      </view>
    </view>

    <!-- 毛色 -->
    <view class="form-item">
      <view class="item-left">
        <text class="label">毛色</text>
      </view>
      <input class="input" placeholder="请输入毛色" value="{{color}}" data-field="color" bindinput="onInput" />
    </view>

    <!-- 默认宠物 -->
    <view class="form-item switch-item">
      <view class="item-left">
        <text class="label">设为默认宠物</text>
      </view>
      <switch checked="{{isDefault}}" bindchange="onDefaultChange" color="#ff9a6a" />
    </view>

    <!-- 备注 -->
    <view class="form-item textarea-item">
      <view class="item-left">
        <text class="label">备注</text>
      </view>
      <textarea class="textarea" placeholder="添加备注信息..." value="{{remark}}" data-field="remark" bindinput="onInput" maxlength="200"></textarea>
    </view>
  </view>

  <!-- 保存按钮 -->
  <view class="footer">
    <view class="save-btn {{saving ? 'disabled' : ''}}" bindtap="save">
      <text wx:if="{{!saving}}">保存</text>
      <text wx:else>保存中...</text>
    </view>
  </view>
</view>
