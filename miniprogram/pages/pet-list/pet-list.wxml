<view class="container">
  <!-- 顶部导航 -->
  <view class="nav-bar">
    <view class="back-btn" bindtap="goBack">
      <text class="back-icon">‹</text>
    </view>
    <text class="nav-title">我的宠物</text>
    <view class="nav-right">
      <view class="add-mini-btn" bindtap="goAdd">
        <text class="add-mini-icon">+</text>
      </view>
    </view>
  </view>

  <!-- 宠物列表 -->
  <scroll-view class="pet-scroll" scroll-y enhanced show-scrollbar="{{false}}" bindrefresherrefresh="onRefresh" refresher-enabled refresher-triggered="{{refreshing}}">
    <view class="pet-list">
      <!-- 加载中 -->
      <view wx:if="{{loading}}" class="loading-state">
        <view class="loading-spinner"></view>
        <text class="loading-text">加载中...</text>
      </view>

      <!-- 空状态 -->
      <view wx:if="{{pets.length === 0 && !loading}}" class="empty-state">
        <view class="empty-illustration">
          <view class="empty-paw">🐾</view>
          <view class="empty-paw empty-paw-2">🐾</view>
          <view class="empty-paw empty-paw-3">🐾</view>
        </view>
        <text class="empty-text">还没有添加宠物</text>
        <text class="empty-subtext">快来创建你的第一个宠物档案吧</text>
        <view class="empty-add-btn" bindtap="goAdd">
          <text class="empty-add-icon">+</text>
          <text class="empty-add-text">添加宠物</text>
        </view>
      </view>

      <!-- 宠物卡片列表 -->
      <view wx:for="{{pets}}" wx:key="_id" class="pet-card" bindtap="goEdit" data-id="{{item._id}}">
        <view class="pet-avatar">
          <image wx:if="{{item.avatar}}" class="avatar-img" src="{{item.avatar}}" mode="aspectFill"></image>
          <view wx:else class="avatar-placeholder">{{item.name[0]}}</view>
          <view wx:if="{{item.isDefault}}" class="default-badge">
            <text class="badge-icon">★</text>
            <text class="badge-text">默认</text>
          </view>
        </view>
        
        <view class="pet-info">
          <view class="pet-header">
            <text class="pet-name">{{item.name}}</text>
            <text class="pet-type">{{item.type === 'cat' ? '🐱' : item.type === 'dog' ? '🐶' : '🐾'}}</text>
          </view>
          <view class="pet-detail">
            <text wx:if="{{item.breed}}" class="detail-item breed">{{item.breed}}</text>
            <text wx:if="{{item.gender}}" class="detail-item gender {{item.gender === 'male' ? 'male' : 'female'}}">
              {{item.gender === 'male' ? '♂' : '♀'}}
            </text>
            <text wx:if="{{item.weight}}" class="detail-item weight">{{item.weight}}kg</text>
          </view>
          <text wx:if="{{item.remark}}" class="pet-remark">{{item.remark}}</text>
        </view>

        <view class="pet-actions" catchtap="stopPropagation">
          <view wx:if="{{!item.isDefault}}" class="action-btn default-btn" catchtap="setDefault" data-id="{{item._id}}">
            <text class="action-icon">★</text>
            <text class="action-text">设为默认</text>
          </view>
          <view class="action-btn delete-btn" catchtap="deletePet" data-id="{{item._id}}">
            <text class="action-icon">🗑</text>
            <text class="action-text">删除</text>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- 底部添加按钮 -->
  <view class="add-fab" bindtap="goAdd">
    <text class="fab-icon">+</text>
  </view>
</view>