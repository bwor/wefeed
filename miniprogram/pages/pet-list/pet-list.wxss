.container {
  min-height: 100vh;
  background: #fffdf8;
  padding-bottom: 160rpx;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: #fff;
  border-bottom: 2rpx solid #ffe5c2;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 48rpx;
  color: #ff8c42;
  font-weight: 300;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.nav-right {
  width: 60rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 60rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.empty-subtext {
  font-size: 26rpx;
  color: #999;
}

/* 宠物卡片 */
.pet-list {
  padding: 30rpx;
}

.pet-card {
  background: #fff;
  border-radius: 25rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 20rpx rgba(255, 165, 0, 0.1);
  border: 2rpx solid #ffe5c2;
}

.pet-avatar {
  position: relative;
  margin-right: 24rpx;
}

.avatar-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  object-fit: cover;
}

.avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ff9a6a 0%, #ff7e5f 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #fff;
  font-weight: 600;
}

.default-badge {
  position: absolute;
  bottom: 0;
  right: 0;
  background: #ffe680;
  color: #333;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-weight: 600;
}

.pet-info {
  flex: 1;
  min-width: 0;
}

.pet-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.pet-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  margin-right: 16rpx;
}

.pet-type {
  font-size: 24rpx;
  color: #ff8c42;
  background: #fff3e6;
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
}

.pet-detail {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 8rpx;
}

.detail-item {
  font-size: 26rpx;
  color: #666;
  margin-right: 20rpx;
}

.pet-remark {
  font-size: 24rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.pet-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.action-btn {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  text-align: center;
}

.default-btn {
  color: #ff8c42;
  background: #fff3e6;
}

.delete-btn {
  color: #ff5a5f;
  background: #ffe6e6;
}

/* 添加按钮 */
.add-btn {
  position: fixed;
  left: 50%;
  bottom: 60rpx;
  transform: translateX(-50%);
  background: linear-gradient(135deg, #ff9a6a 0%, #ff7e5f 100%);
  color: white;
  padding: 24rpx 60rpx;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 25rpx rgba(255, 126, 95, 0.4);
}

.add-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
  font-weight: 300;
}

.add-text {
  font-size: 32rpx;
  font-weight: 600;
}
