/* 容器 */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #fff5e6 0%, #fffdf8 100%);
  padding-bottom: 180rpx;
  position: relative;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 30rpx;
  background: #fff;
  border-bottom: 2rpx solid #ffe5c2;
  position: sticky;
  top: 0;
  z-index: 100;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #fff9f5;
  transition: all 0.2s ease;
}

.back-btn:active {
  background: #ffe5c2;
}

.back-icon {
  font-size: 48rpx;
  color: #ff8c42;
  font-weight: 300;
  line-height: 1;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
}

.nav-right {
  width: 60rpx;
  display: flex;
  justify-content: flex-end;
}

.add-mini-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: linear-gradient(135deg, #ff9a6a 0%, #ff7e5f 100%);
  box-shadow: 0 4rpx 12rpx rgba(255, 126, 95, 0.3);
}

.add-mini-icon {
  font-size: 32rpx;
  color: #fff;
  font-weight: 300;
}

/* 滚动容器 */
.pet-scroll {
  height: calc(100vh - 120rpx);
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #ffe5c2;
  border-top-color: #ff8c42;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 60rpx 60rpx;
}

.empty-illustration {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 40rpx;
}

.empty-paw {
  position: absolute;
  font-size: 80rpx;
  animation: float 3s ease-in-out infinite;
}

.empty-paw:first-child {
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 100rpx;
}

.empty-paw-2 {
  top: 20%;
  left: 20%;
  font-size: 50rpx;
  animation-delay: 0.5s;
}

.empty-paw-3 {
  top: 30%;
  right: 10%;
  font-size: 60rpx;
  animation-delay: 1s;
}

@keyframes float {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  50% { transform: translateY(-20rpx) rotate(10deg); }
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.empty-subtext {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.empty-add-btn {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #ff9a6a 0%, #ff7e5f 100%);
  color: #fff;
  padding: 24rpx 48rpx;
  border-radius: 50rpx;
  box-shadow: 0 8rpx 25rpx rgba(255, 126, 95, 0.4);
}

.empty-add-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
  font-weight: 300;
}

.empty-add-text {
  font-size: 30rpx;
  font-weight: 600;
}

/* 宠物列表 */
.pet-list {
  padding: 30rpx;
}

/* 宠物卡片 */
.pet-card {
  background: #fff;
  border-radius: 30rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 30rpx rgba(255, 165, 0, 0.12);
  border: 2rpx solid #ffe5c2;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.pet-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #ff9a6a 0%, #ff7e5f 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.pet-card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 20rpx rgba(255, 165, 0, 0.15);
}

.pet-card:active::before {
  opacity: 1;
}

.pet-card.is-default {
  border-color: #ffd700;
  box-shadow: 0 8rpx 30rpx rgba(255, 215, 0, 0.2);
}

.pet-card.is-default::before {
  opacity: 1;
}

/* 宠物头像 */
.pet-avatar {
  position: relative;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.avatar-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  object-fit: cover;
  border: 4rpx solid #fff;
  box-shadow: 0 4rpx 15rpx rgba(255, 154, 106, 0.2);
}

.avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ff9a6a 0%, #ff7e5f 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #fff;
  font-weight: 600;
  border: 4rpx solid #fff;
  box-shadow: 0 4rpx 15rpx rgba(255, 154, 106, 0.2);
}

.default-badge {
  position: absolute;
  bottom: 0rpx;
  right: 0rpx;
  background: linear-gradient(135deg, #ffd700 0%, #ffb800 100%);
  color: #fff;
  font-size: 18rpx;
  padding: 6rpx 14rpx;
  border-radius: 16rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  gap: 4rpx;
  box-shadow: 0 4rpx 10rpx rgba(255, 184, 0, 0.4);
}

.badge-icon {
  font-size: 16rpx;
}

/* 宠物信息 */
.pet-info {
  flex: 1;
  min-width: 0;
}

.pet-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.pet-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
  margin-right: 16rpx;
}

.pet-type {
  font-size: 28rpx;
}

.pet-detail {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 8rpx;
  gap: 12rpx;
}

.detail-item {
  font-size: 24rpx;
  color: #666;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.detail-item.breed {
  background: #fff5e6;
  color: #ff8c42;
}

.detail-item.gender {
  background: #f0f0f0;
}

.detail-item.gender.male {
  background: #e3f2fd;
  color: #2196f3;
}

.detail-item.gender.female {
  background: #fce4ec;
  color: #e91e63;
}

.detail-item.weight {
  background: #e8f5e9;
  color: #4caf50;
}

.pet-remark {
  font-size: 24rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
}

/* 操作按钮 */
.pet-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-left: 20rpx;
}

.action-btn {
  font-size: 22rpx;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  white-space: nowrap;
  transition: all 0.2s ease;
}

.action-btn:active {
  transform: scale(0.95);
}

.default-btn {
  color: #ff8c42;
  background: #fff5e6;
}

.default-btn .action-icon {
  font-size: 20rpx;
}

.delete-btn {
  color: #ff5a5f;
  background: #ffe6e6;
}

.delete-btn .action-icon {
  font-size: 18rpx;
}

/* 底部悬浮按钮 */
.add-fab {
  position: fixed;
  left: 50%;
  bottom: 60rpx;
  transform: translateX(-50%);
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #ff9a6a 0%, #ff7e5f 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 40rpx rgba(255, 126, 95, 0.5);
  z-index: 200;
  transition: all 0.3s ease;
}

.add-fab:active {
  transform: translateX(-50%) scale(0.9);
}

.fab-icon {
  font-size: 60rpx;
  color: #fff;
  font-weight: 300;
  line-height: 1;
}