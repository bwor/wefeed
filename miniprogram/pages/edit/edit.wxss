/* 页面背景 */
.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx;
  box-sizing: border-box;
}

/* 单条白块 */
.item {
  height: 112rpx;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 0 32rpx;

  display: flex;
  align-items: center;
  justify-content: space-between;

  margin-bottom: 24rpx;
}

/* 左侧 */
.item-left {
  display: flex;
  align-items: center;
}

/* 红色竖条（重点） */
.mark {
  width: 6rpx;
  height: 32rpx;
  background: #ff5a5f;
  border-radius: 3rpx;
  margin-right: 16rpx;
}

/* 标题文字 */
.title {
  font-size: 30rpx;
  font-weight: 400;
  color: #333333;
}

/* 输入框 */
.item-input {
  font-size: 28rpx;
  color: #333;
  text-align: right;
}

.ph {
  color: #bfbfbf;
}

/* 头像按钮 */
.avatar-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #eeeeee;
  padding: 0;
  margin: 0;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-btn::after {
  border: none;
}

.avatar-img {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
}

.camera {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.85;
}

/* 中间留白 */
.gap {
  height: 32rpx;
}

/* 注销 */
.logout {
  margin-bottom: 0;
}

.arrow {
  font-size: 32rpx;
  color: #c7c7c7;
}

/* 底部按钮 */
.footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 48rpx;
  padding: 0 32rpx;
}

.submit {
  height: 96rpx;
  background: #ffe680;
  border-radius: 48rpx;

  display: flex;
  align-items: center;
  justify-content: center;

  font-size: 34rpx;
  color: #333;
}
