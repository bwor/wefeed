.calendar-container {
  padding: 20rpx;
  background: linear-gradient(135deg, #fdfbfb 0%, #ebedee 100%);
  min-height: 100vh;
  padding-bottom: 100rpx;
}

/* 日历头部 */
.calendar-header {
  margin-bottom: 20rpx;
}

.calendar-nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 10rpx 30rpx rgba(102, 126, 234, 0.3);
}

.nav-btn {
  font-size: 40rpx;
  background: none;
  border: none;
  padding: 10rpx;
  color: white;
  opacity: 0.9;
  transition: all 0.3s;
}

.nav-btn:active {
  opacity: 1;
  transform: scale(1.1);
}

.month-year {
  font-size: 32rpx;
  font-weight: bold;
  color: white;
  letter-spacing: 2rpx;
}

/* 日历主体 */
.calendar-main {
  margin-bottom: 30rpx;
}

/* 星期标题 */
.weekdays {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
  background-color: white;
  padding: 20rpx 0;
  border-radius: 15rpx;
  box-shadow: 0 5rpx 15rpx rgba(0, 0, 0, 0.08);
}

.weekday {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  color: #667eea;
  font-weight: 600;
}

/* 日历网格 */
.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 8rpx;
  background-color: white;
  padding: 25rpx;
  border-radius: 20rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.1);
}

.calendar-day {
  position: relative;
  height: 110rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  cursor: pointer;
  transition: all 0.3s;
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
}

.calendar-day:hover {
  transform: scale(1.05);
  box-shadow: 0 5rpx 15rpx rgba(0, 0, 0, 0.1);
}

.calendar-day.selected {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  transform: scale(1.1);
  box-shadow: 0 10rpx 20rpx rgba(102, 126, 234, 0.4);
}

.calendar-day.today {
  border: 3rpx solid #667eea;
  background: linear-gradient(135deg, #fdfbfb 0%, #ebedee 100%);
}

.calendar-day.other-month {
  color: #ccc;
  opacity: 0.6;
}

.day-number {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.calendar-day.selected .day-number {
  color: white;
}

.calendar-day.today .day-number {
  color: #667eea;
  font-weight: bold;
}

.event-dot {
  position: absolute;
  bottom: 15rpx;
  width: 10rpx;
  height: 10rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a24 100%);
  border-radius: 50%;
  box-shadow: 0 2rpx 5rpx rgba(255, 107, 107, 0.4);
}

/* 事件区域 */
.event-section {
  margin-bottom: 20rpx;
}

/* 事件列表 */
.event-list {
  background-color: white;
  border-radius: 20rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.1);
  padding: 25rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid #f0f0f0;
}

.event-list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 25rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.event-list-header text {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.add-event-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  padding: 12rpx 25rpx;
  border-radius: 25rpx;
  font-size: 24rpx;
  font-weight: 500;
  box-shadow: 0 5rpx 15rpx rgba(102, 126, 234, 0.3);
  transition: all 0.3s;
  margin: 0;
}

.add-event-btn:active {
  transform: scale(0.95);
  box-shadow: 0 3rpx 10rpx rgba(102, 126, 234, 0.3);
}

.no-events {
  text-align: center;
  padding: 80rpx 40rpx;
  color: #999;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.no-events text:first-child {
  display: block;
  font-size: 28rpx;
  margin-bottom: 10rpx;
}

.hint {
  display: block;
  font-size: 24rpx;
  color: #bbb;
  margin-top: 10rpx;
}

.event-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  transition: all 0.3s;
}

.event-item:last-child {
  border-bottom: none;
}

.event-item:hover {
  background-color: #f9f9f9;
  border-radius: 10rpx;
  padding: 20rpx 15rpx;
}

.event-left {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 15rpx;
  flex-shrink: 0;
}

.event-time {
  font-size: 24rpx;
  color: #667eea;
  font-weight: 500;
  margin-bottom: 5rpx;
}

.event-dot-small {
  width: 8rpx;
  height: 8rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a24 100%);
  border-radius: 50%;
}

.event-center {
  flex: 1;
  margin-right: 15rpx;
  display: flex;
  flex-direction: column;
}

.event-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.event-note {
  font-size: 22rpx;
  color: #999;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.event-right {
  flex-shrink: 0;
}

.delete-event-btn {
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a24 100%);
  color: white;
  border: none;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  transition: all 0.3s;
}

.delete-event-btn:active {
  transform: scale(0.95);
}

/* 添加事项表单 */
.add-event-form {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(180deg, #ffffff 0%, #f9fafb 100%);
  border-top-left-radius: 50rpx;
  border-top-right-radius: 50rpx;
  box-shadow: 0 -15rpx 40rpx rgba(0, 0, 0, 0.1);
  padding: 50rpx;
  z-index: 1000;
  animation: slideUp 0.5s ease-out;
  max-height: 85vh;
  overflow-y: auto;
  border-top: 2rpx solid #f0f0f0;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

.form-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 45rpx;
  padding-bottom: 25rpx;
  border-bottom: 3rpx solid #f0f0f0;
}

.form-header text {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: 2rpx;
}

.close-btn {
  font-size: 52rpx;
  background: none;
  border: none;
  color: #999;
  padding: 0;
  line-height: 1;
  transition: all 0.4s;
  margin: 0;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: all 0.3s;
}

.close-btn:hover {
  color: #667eea;
  transform: scale(1.2);
  background-color: #f5f7fa;
}

.form-item {
  margin-bottom: 40rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #667eea;
  margin-bottom: 18rpx;
  letter-spacing: 1rpx;
}

input,
textarea {
  border: 3rpx solid #e8eaf6;
  border-radius: 18rpx;
  padding: 28rpx 22rpx;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
  transition: all 0.4s;
  background-color: #fcfcfc;
  color: #444;
  line-height: 1.6;
  height: 100rpx;
}

input:focus,
textarea:focus {
  border-color: #667eea;
  background-color: white;
  box-shadow: 0 8rpx 25rpx rgba(102, 126, 234, 0.15);
  transform: translateY(-2rpx);
}

textarea {
  min-height: 220rpx;
  resize: none;
  line-height: 1.6;
  padding: 28rpx 22rpx;
}

.picker {
  border: 3rpx solid #e8eaf6;
  border-radius: 18rpx;
  padding: 28rpx 22rpx;
  font-size: 28rpx;
  color: #444;
  background-color: #fcfcfc;
  transition: all 0.4s;
  line-height: 1.6;
  min-height: 80rpx;
  display: flex;
  align-items: center;
}

.picker:focus {
  border-color: #667eea;
  background-color: white;
  box-shadow: 0 8rpx 25rpx rgba(102, 126, 234, 0.15);
  transform: translateY(-2rpx);
}

.picker:active {
  border-color: #667eea;
  background-color: white;
}

.form-actions {
  display: flex;
  gap: 25rpx;
  margin-top: 40rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid #f0f0f0;
}

.cancel-btn {
  flex: 1;
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  color: #667eea;
  border: none;
  padding: 30rpx;
  border-radius: 20rpx;
  font-size: 30rpx;
  font-weight: bold;
  transition: all 0.4s;
  box-shadow: 0 5rpx 15rpx rgba(102, 126, 234, 0.1);
}

.cancel-btn:active {
  background: linear-gradient(135deg, #e8eaf6 0%, #b0c4de 100%);
  transform: scale(0.98);
  box-shadow: 0 3rpx 10rpx rgba(102, 126, 234, 0.1);
}

.submit-btn {
  flex: 1;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  padding: 30rpx;
  border-radius: 20rpx;
  font-size: 30rpx;
  font-weight: bold;
  box-shadow: 0 12rpx 30rpx rgba(102, 126, 234, 0.4);
  transition: all 0.4s;
  letter-spacing: 2rpx;
}

.submit-btn:active {
  transform: scale(0.98);
  box-shadow: 0 8rpx 20rpx rgba(102, 126, 234, 0.3);
}

.submit-btn:hover {
  box-shadow: 0 15rpx 35rpx rgba(102, 126, 234, 0.45);
}
