/* 容器 */
.container {
  min-height: 100vh;
  padding: 0;
  box-sizing: border-box;
  background: linear-gradient(180deg, #fff5e6 0%, #fffdf8 30%, #fffdf8 100%);
  position: relative;
}

/* 顶部背景装饰 */
.header-bg {
  height: 320rpx;
  background: linear-gradient(135deg, #ff9a6a 0%, #ff7e5f 100%);
  border-radius: 0 0 60rpx 60rpx;
  position: relative;
  overflow: hidden;
}

.header-bg::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
  animation: shimmer 3s infinite;
}

@keyframes shimmer {
  0%, 100% { transform: translate(0, 0); }
  50% { transform: translate(-20%, -20%); }
}

/* 个人资料卡片 */
.profile-card {
  background: #fff;
  border-radius: 40rpx;
  padding: 0 0 50rpx;
  margin: -200rpx 30rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  box-shadow: 0 20rpx 60rpx rgba(255, 154, 106, 0.2);
}

/* 头像容器 */
.avatar-wrapper {
  position: relative;
  margin-top: 60rpx;
}

.avatar-ring {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 154, 106, 0.3);
  animation: pulse 2s infinite;
}

.avatar-ring-2 {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255, 154, 106, 0.15);
  animation: pulse 2s infinite 0.5s;
}

@keyframes pulse {
  0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 1; }
  50% { transform: translate(-50%, -50%) scale(1.1); opacity: 0.5; }
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 6rpx solid #fff;
  box-shadow: 0 10rpx 30rpx rgba(255, 154, 106, 0.3);
  background: linear-gradient(135deg, #fff5e6 0%, #ffe5c2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.avatar-default {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-icon {
  font-size: 60rpx;
}

/* 昵称区域 */
.nickname-section {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 30rpx;
  gap: 16rpx;
}

.nickname {
  font-size: 42rpx;
  font-weight: 700;
  color: #333;
}

.vip-badge {
  background: linear-gradient(135deg, #ffd700 0%, #ffb800 100%);
  color: #fff;
  font-size: 22rpx;
  font-weight: 700;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 184, 0, 0.4);
}

/* 统计信息 */
.stats-row {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 40rpx;
  padding: 0 60rpx;
  gap: 40rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #ff8c42;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: #ffe5c2;
}

/* 功能菜单 */
.menu-section {
  padding: 0 30rpx;
}

.menu-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #666;
  margin-bottom: 20rpx;
  padding-left: 10rpx;
}

.menu-list {
  background: #fff;
  border-radius: 30rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 30rpx rgba(255, 154, 106, 0.1);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx 30rpx;
  border-bottom: 2rpx solid #f8f8f8;
  transition: background 0.2s ease;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #fff9f5;
}

.menu-icon {
  font-size: 44rpx;
  margin-right: 24rpx;
}

.menu-text {
  flex: 1;
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.menu-arrow {
  font-size: 36rpx;
  color: #ccc;
}