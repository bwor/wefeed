.container {
  min-height: 100vh;
  padding: 40rpx 30rpx 0;
  box-sizing: border-box;
  background: #fffdf8;
}

.profile-card {
  width: 100%;
  max-width: 600rpx;
  background: #fff;
  border-radius: 25rpx;
  box-shadow: 0 12rpx 30rpx rgba(255, 165, 0, 0.15);
  padding: 80rpx 40rpx 50rpx;
  margin: 0 auto 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  border: 2rpx solid #ffe5c2;
}

.avatar-container {
  position: absolute;
  top: -70rpx;
  left: 50%;
  transform: translateX(-50%);
}

.avatar {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 8rpx solid #fff;
  box-shadow: 0 8rpx 20rpx rgba(255, 165, 0, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff9eb;
}

.img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.nickname {
  font-size: 40rpx;
  font-weight: 700;
  color: #ff8c42;
  margin: 70rpx 0 20rpx;
  text-align: center;
  font-family: 'PingFang SC', 'Heiti SC', sans-serif;
}

.pet-info {
  width: 100%;
  text-align: center;
  margin: 20rpx 0 40rpx;
  color: #ff9a6a;
  font-size: 28rpx;
}

.edit-btn {
  width: 100%;
  max-width: 500rpx;
  background: linear-gradient(135deg, #ff9a6a 0%, #ff7e5f 100%);
  color: white;
  border: none;
  border-radius: 50rpx;
  padding: 32rpx;
  font-size: 34rpx;
  font-weight: 600;
  margin: 30rpx auto 0;
  box-shadow: 0 8rpx 25rpx rgba(255, 126, 95, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.edit-btn::after {
  border: none;
}

.edit-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

/* 宠物管理按钮 */
.pet-btn {
  width: 100%;
  max-width: 500rpx;
  background: #fff;
  color: #333;
  border: 2rpx solid #ffe5c2;
  border-radius: 50rpx;
  padding: 32rpx;
  font-size: 34rpx;
  font-weight: 600;
  margin: 20rpx auto 0;
  box-shadow: 0 8rpx 25rpx rgba(255, 165, 0, 0.15);
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: relative;
  overflow: hidden;
}

.pet-btn::after {
  border: none;
}

.pet-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.pet-btn-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.pet-btn-text {
  flex: 1;
  text-align: left;
  color: #ff8c42;
}

.pet-btn-arrow {
  font-size: 32rpx;
  color: #ccc;
}

/* 添加可爱的装饰元素 */
.decoration-element {
  position: absolute;
  width: 40rpx;
  height: 40rpx;
  background: rgba(255, 154, 106, 0.1);
  border-radius: 50%;
  z-index: 0;
}

.decoration-1 {
  top: 20rpx;
  left: 20rpx;
}

.decoration-2 {
  bottom: 30rpx;
  right: 30rpx;
  width: 60rpx;
  height: 60rpx;
  background: rgba(255, 180, 120, 0.15);
}

.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
  width: 100%;
}
