<view class="container">
  <!-- 顶部装饰 -->
  <view class="header-decoration">
    <view class="decoration-circle decoration-circle-1"></view>
    <view class="decoration-circle decoration-circle-2"></view>
    <view class="decoration-circle decoration-circle-3"></view>
  </view>

  <!-- 个人资料卡片 -->
  <view class="profile-card">
    <!-- 可爱装饰元素 -->
    <view class="card-decoration card-decoration-1">🐾</view>
    <view class="card-decoration card-decoration-2">🐶</view>
    
    <!-- 头像容器 -->
    <view class="avatar-wrapper">
      <view class="avatar">
        <image wx:if="{{avatarUrl}}" class="img" src="{{avatarUrl}}" mode="aspectFill"></image>
        <view wx:else class="avatar-default">
          <text class="avatar-icon">🐾</text>
        </view>
        <view class="avatar-border"></view>
      </view>
    </view>
    
    <!-- 昵称 -->
    <view class="nickname-section">
      <text class="nickname">{{nickname || '点击编辑昵称'}}</text>
      <text class="pet-owner-badge">宠物主人</text>
    </view>
  </view>
  
  <!-- 功能菜单 -->
  <view class="menu-section">
    <view class="menu-card">
      <view class="menu-item" bindtap="goPetList">
        <view class="menu-icon-wrapper">
          <view class="menu-icon menu-icon-pet">🐕</view>
        </view>
        <text class="menu-text">我的宠物</text>
        <view class="menu-arrow-container">
          <text class="menu-arrow">›</text>
        </view>
      </view>
      
      <view class="menu-item" bindtap="goEdit">
        <view class="menu-icon-wrapper">
          <view class="menu-icon menu-icon-edit">✏️</view>
        </view>
        <text class="menu-text">编辑资料</text>
        <view class="menu-arrow-container">
          <text class="menu-arrow">›</text>
        </view>
      </view>
      
      <view class="menu-item">
        <view class="menu-icon-wrapper">
          <view class="menu-icon menu-icon-help">❓</view>
        </view>
        <text class="menu-text">帮助与反馈</text>
        <view class="menu-arrow-container">
          <text class="menu-arrow">›</text>
        </view>
      </view>
      
      <view class="menu-item">
        <view class="menu-icon-wrapper">
          <view class="menu-icon menu-icon-about">ℹ️</view>
        </view>
        <text class="menu-text">关于我们</text>
        <view class="menu-arrow-container">
          <text class="menu-arrow">›</text>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 底部信息 -->
  <view class="footer">
    <text class="footer-text">喂呗 v1.0.0</text>
  </view>
</view>
