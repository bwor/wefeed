<view class="container">
  <!-- 个人资料卡片 -->
  <view class="profile-card">
    <!-- 头像容器 -->
    <view class="avatar-wrapper">
      <view class="avatar">
        <image wx:if="{{avatarUrl}}" class="img" src="{{avatarUrl}}" mode="aspectFill"></image>
        <view wx:else class="avatar-default">
          <text class="avatar-icon">🐾</text>
        </view>
      </view>
    </view>
    
    <!-- 昵称 -->
    <view class="nickname-section">
      <text class="nickname">{{nickname || '点击编辑昵称'}}</text>
    </view>
  </view>
  
  <!-- 功能菜单 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="goPetList">
      <view class="menu-icon">🐕</view>
      <text class="menu-text">我的宠物</text>
      <text class="menu-arrow">›</text>
    </view>
    
    <view class="menu-item" bindtap="goEdit">
      <view class="menu-icon">✏️</view>
      <text class="menu-text">编辑资料</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>
</view>