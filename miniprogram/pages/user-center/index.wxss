/* 容器 */
.container {
  min-height: 100vh;
  background: #fffdf8;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

/* 个人资料卡片 */
.profile-card {
  background: #fff;
  padding: 48rpx 32rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border-bottom: 1rpx solid #f0f0f0;
  justify-content: flex-start;
}

.avatar {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 4rpx solid #ffe5c2;
  background: linear-gradient(135deg, #fff5e6 0%, #ffe5c2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.avatar-default {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-icon {
  font-size: 60rpx;
}

.nickname-section {
  margin-top: 24rpx;
}

.nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

/* 功能菜单 */
.menu-section {
  margin-top: 32rpx;
  width: 100%;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 36rpx 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
  background: #fff;
  width: 100%;
  box-sizing: border-box;
}

.menu-item:first-child {
  border-top: 1rpx solid #f5f5f5;
}

.menu-item:active {
  background: #fff9f5;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 24rpx;
}

.menu-text {
  flex: 1;
  font-size: 32rpx;
  color: #333;
}

.menu-arrow {
  font-size: 32rpx;
  color: #ccc;
}