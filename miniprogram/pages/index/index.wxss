.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  box-sizing: border-box;
  background: #fffdf8;
}

.title {
  font-size: 52rpx;
  font-weight: 800;
  margin-bottom: 50rpx;
  background: linear-gradient(135deg, #ff9a6a 0%, #ff7e5f 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  text-align: center;
  font-family: 'Comic Sans MS', 'PingFang SC', 'Heiti SC', cursive;
  letter-spacing: 4rpx;
}

.main-btn {
  width: 80%;
  max-width: 400rpx;
  background: linear-gradient(135deg, #ff9a6a 0%, #ff7e5f 100%);
  color: #fff;
  border: none;
  border-radius: 50rpx;
  padding: 34rpx 0;
  font-size: 34rpx;
  font-weight: 600;
  margin: 30rpx 0;
  box-shadow: 0 8rpx 25rpx rgba(255, 126, 95, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.main-btn::after {
  border: none;
}

.main-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.result {
  margin-top: 24rpx;
  color: #ff9a6a;
}
