/* 容器 */
.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  box-sizing: border-box;
  background: #fffdf8;
}

.title {
  font-size: 52rpx;
  font-weight: 800;
  margin-bottom: 20rpx;
  background: linear-gradient(135deg, #ff9a6a 0%, #ff7e5f 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  text-align: center;
  font-family: 'PingFang SC', 'Heiti SC', cursive;
  letter-spacing: 4rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #999;
  text-align: center;
}