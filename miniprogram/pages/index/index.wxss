/* 容器 */
.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 40rpx 30rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #fffdf8 0%, #fff5e6 100%);
  position: relative;
  overflow: hidden;
}

/* 顶部装饰 */
.header-decoration {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 200rpx;
  overflow: hidden;
  pointer-events: none;
}

.deco-dot {
  position: absolute;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(255, 154, 106, 0.15) 0%, rgba(255, 126, 95, 0.1) 100%);
}

.deco-dot-1 {
  width: 120rpx;
  height: 120rpx;
  top: 20rpx;
  left: -40rpx;
}

.deco-dot-2 {
  width: 80rpx;
  height: 80rpx;
  top: 60rpx;
  right: 40rpx;
}

.deco-dot-3 {
  width: 60rpx;
  height: 60rpx;
  top: 140rpx;
  left: 50%;
}

/* Logo 区域 */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 40rpx;
}

.logo-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
  animation: bounce 2s infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-20rpx); }
}

.title {
  font-size: 64rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #ff9a6a 0%, #ff7e5f 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  text-align: center;
  font-family: 'PingFang SC', 'Heiti SC', sans-serif;
  letter-spacing: 8rpx;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #999;
  text-align: center;
  font-weight: 400;
  letter-spacing: 2rpx;
}

/* 功能卡片区域 */
.feature-cards {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
  padding: 40rpx 0;
}

.feature-card {
  background: #fff;
  border-radius: 30rpx;
  padding: 40rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 12rpx 40rpx rgba(255, 154, 106, 0.15);
  border: 2rpx solid rgba(255, 229, 194, 0.5);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.feature-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(255, 154, 106, 0.05) 0%, rgba(255, 126, 95, 0.05) 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.feature-card:active::before {
  opacity: 1;
}

.feature-card:active {
  transform: scale(0.98);
}

.feature-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.feature-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 8rpx;
}

.feature-desc {
  font-size: 26rpx;
  color: #999;
}

/* 欢迎提示 */
.welcome-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(255, 154, 106, 0.1) 0%, rgba(255, 126, 95, 0.1) 100%);
  border-radius: 25rpx;
  padding: 24rpx 30rpx;
  margin-top: auto;
  border: 2rpx solid rgba(255, 229, 194, 0.5);
}

.welcome-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.welcome-text {
  font-size: 28rpx;
  color: #ff8c42;
  font-weight: 500;
}